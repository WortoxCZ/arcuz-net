textNpc1 = [];
var i = 0;
while(i <= 26)
{
   textNpc1[i] = [];
   i++;
}
textNpc1[0].push("欢迎来到奥库兹村，年轻人。我是村长维恩。已经好久没有冒险者到访这个村庄了，昨晚的祈祷看来真的起了作用……真的很欢迎你的到来。");
textNpc1[1].push("从我小的时候开始，奥库兹村就是这块大陆上最平静的村庄。居住在村庄里的人们在这儿快乐安详地生活。");
textNpc1[2].push("村庄所在的这片土地属于扎克领主。我是他的管家。他是一位很有抱负的人。村庄的繁荣多亏了他的帮助。");
textNpc1[3].push("可是，一年前，自从扎克领主闭关研读之后，村庄周围出现了大量的魔物。就连平日温顺的动物，都变得狂暴起来。村民失踪和死亡事件不断，人们纷纷离开了这个地方。");
textNpc1[4].push("年轻人，你对这个村庄熟悉一些了吗？接下来，你可以四处走走，到村庄外围去看看。不过一定要小心魔物，它们十分危险……");
textNpc1[5].push("村民们如果需要你的帮助，会在头上显示问号。你可以接受他们的任务，一边帮他们的忙，一边找线索。有时候真相就隐藏在村民的任务之中。");
textNpc1[6].push("我见过许多旅行者，你的身上透露着特别的气质。我相信你一定能在接下来的时间里有所作为的。");
textNpc1[7].push("这块大陆在很早之前有过一场神的战争。在战争中，光明艰难地战胜了黑暗，邪恶的魔王被勇士和魔法师们封印了起来。");
textNpc1[8].push("好像封印魔王的地下城就在村庄附近，但因为年代久远，现在根本找不到了。不知道这次的异常和魔王是否有一定的关系。");
textNpc1[9].push("扎克领主是一个知识渊博的领主，他通晓很多古代的咒语。他以前常常到这个村庄来转转，仔细地问村民生活情况。但自从1年前扎克领主闭关之后，我就再没有见过他。他的城堡也不让外人进去，连管家我也不能。");
textNpc1[10].push("不知道你注意到没有，当你的等级提升后，会学到新的战斗技能。你可以点击Skill按钮，在技能树上将技能点分配到那些新的技能上，并把技能拖拽到屏幕下方右边的2个技能槽中。");
textNpc1[11].push("在战斗中，当你点击I或L的时候，就可以发出强大的技能来。");
textNpc1[12].push("谢谢你帮忙找回安娜！这个孩子，看来不找到父母是不会甘心的啊……");
textNpc1[13].push("熟悉整个世界了吗，年轻人？还有不懂的地方，就多尝试下，摸索也是一件很有乐趣的事情。");
textNpc1[14].push("在帮助村民的过程中，你也获得了不少线索吧？麻烦你继续下去，尽快解决这一切纷扰……");
textNpc1[15].push("这一段时间来，你给了村民们许多帮助。看来他们都把你当成了值得信任的朋友。真的非常感谢你，年轻人！");
textNpc1[16].push("这些天每天都做同样的一个梦：村庄里的土地裂开，恶魔从黑暗中钻出来，整个大陆被黑暗慢慢吞噬……每次都会从梦中惊醒过来……");
textNpc1[17].push("……这个村庄到底发生了些什么，正在发生些什么啊……");
textNpc1[18].push("我的噩梦变成现实了，地下城的入口竟然就在村庄里面……我从小在这个村庄生活，一直以为这只是一个普通的村庄罢了，没想到隐藏了这样大的秘密……");
textNpc1[19].push("或许封印黑暗的勇士们不想让黑暗重返大地，所以把地下城的位置也隐藏了起来……");
textNpc1[20].push("扎克领主为了永生，就要背叛整个大陆吗？这是我万万没有想到的……作为他的管家却一直被蒙在鼓里……");
textNpc1[21].push("事情发展到这个地步，我有不可推卸的责任……年轻人，多亏了你的帮助我们才能及时发现事情的真相。");
textNpc1[22].push("事情变得越来越棘手了，我很抱歉把你卷入进这场纷争……");
textNpc1[23].push("为了这个大陆上所有人能够和平快乐地生活，请你一定要继续帮助我们！不过，也请你保护好自己！");
textNpc1[24].push("作为一名勇者，在听说了奥库兹村的异样后，");
textNpc1[25].push("你不远千里来到了这个村庄一探究竟……");
textNpc1[26].push("先找村长了解一下情况吧。走到村长面前，按J键与他对话。");
textNpc2 = [];
var i = 0;
while(i <= 16)
{
   textNpc2[i] = [];
   i++;
}
textNpc2[0].push("你好！我是这个村子的铁匠！我叫格兰！");
textNpc2[1].push("我的家族世世代代都是这里的铁匠，我希望我从父亲和爷爷那里继承到了一个出色铁匠应该具备的实力……！");
textNpc2[2].push("我真的具备了吗？");
textNpc2[3].push("村长维恩让你过来取武器的吗？看来你接受了他的委托！太好了！我这里有刀、剑、斧三种武器，你可以选择自己喜欢的武器。以后你还可以在我这里来买盾牌、皮甲之类的防具。");
textNpc2[4].push("我争取打造出好的东西给你！不过不知道能不能超过父亲和爷爷的手艺！");
textNpc2[5].push("因为出生在和平年代，我总是对自己打造的武器和防具没有太多信心！真想找父亲和爷爷再学学！可是他们已经不在了！");
textNpc2[6].push("我还要多多练习打造武器和防具！因为不是太有信心！普通的家用工具那是完全没问题的了！");
textNpc2[7].push("你不喜欢我的东西吗？还是觉得我的手艺有问题？！我爷爷还在就好了！他经历过战争的年代，听说还曾经为勇士打造过武器呢！");
textNpc2[8].push("我正在试着打造更好的装备！不过手艺能再好些就好了！和爷爷比应该还差得很远！");
textNpc2[9].push("听说任何普通武器和防具上都可以镶元素石，来提高它们的属性！我不太懂合成！具体你要去问问苏珊！有时间的话我也想学习一下！不过我能学会吗？！");
textNpc2[10].push("虽然已经打造了这么多武器，可是对自己还是不太自信啊……！是不是在和平年代出生的铁匠都会有这样的心理呢……？！");
textNpc2[11].push("武器的话，刀、斧和剑都各有各的特色，你可以针对自己喜欢的武器专门修炼相对应的技能。");
textNpc2[12].push("武器和防具有合成的次数限制！也就是说，合成次数达到一定的上限，就不能再合成了！这是不可避免的！我先还以为是自己打造的缺陷！结果后来发现这是矿石的耐久度问题！");
textNpc2[13].push("自从你到这个村庄来了之后，我打造武器的手艺大有进步！多亏了你的经常光顾！我希望自己能够成为一个打造出惊世装备的铁匠！不过先要超过已经拥有这个称号的爷爷才行！");
textNpc2[14].push("最近好像发生了很多大事情呢！希望不要影响到我们普通人的生活就好！不过不管发生了什么，我一定要好好活下去！打造更多更好的装备！");
textNpc2[15].push("有时候我在想，武器是罪恶之源吗？！我的内心就有一个声音告诉我，如果武器被正确的人用在了正确的地方，它就是和平之源啊！");
textNpc2[16].push("朋友！你需要什么装备呢？希望你能满意我的手艺！");

textNpcName[0].push("维恩(村长)");
textNpcName[1].push("格兰(铁匠)");
textNpcName[2].push("苏珊(巫女)");
textNpcName[3].push("钟(商人)");
textNpcName[4].push("保罗(落魄骑士)");

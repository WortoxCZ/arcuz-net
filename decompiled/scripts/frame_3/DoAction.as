textSQuest2[6].push("남자 사이의 내기(부분 임무) ");
textSQuest2[7].push("100마리의 1급 슬라임을 죽여라, 그리고 나서 키무라를 찾아가 과시하라. ");
textSQuest3[0].push("엉엉……오빠……가장 친한 내 친구 테디 베어가 없어졌어……지난번에 침묵의 언덕에 놀러 갔을 때, 너무 피곤하기도 하고 또 너무 무서워서……그만 테디 베어를 잃어 버렸어……");
textSQuest3[1].push("요 며칠 줄 곧 테디 베어를 걱정하고 있지만, 감히 다른 사람들에게는 말할 수가 없었어……왜냐하면 그 테디 베어는 마을 어른들이 내 생일 선물로 주신 거라……엉엉……오빠가 나 대신 좀 찾아 봐 주겠어? ");
textSQuest3[2].push("엉엉……고마워, 오빠! ");
textSQuest3[3].push("엉엉……");
textSQuest3[4].push("엉엉……오빠……내 테디 베어를 찾았어? ");
textSQuest3[5].push("와!! 내 테디 베어!! 고마워 오빠!! 난 오빠가 너무 좋아!! 받아! 이거 내가 주운 예쁜 돌이야! 오빠한테 선물 할께! ");
textSQuest3[6].push("테디 베어(부분 임무) ");
textSQuest3[7].push("침묵의 언덕으로 가서 어린 소녀 안나의 좋은 친구인 테디 베어를 찾아 와라. ");
textSQuest4[0].push("지금 당신 수중에 돈이 얼마 있습니까? 만약 당신이 나를 위해 ３000금을 모은다면, 나는 당신에게 최상의 검 한 자루를 주겠습니다! 아주 많은 속성을 가진 고급 검입니다! 어떻습니까? 돈을 모아서 좋은 물건을 사는 즐거움을 한번 체험해 보고 싶지 않습니까? ");
textSQuest4[1].push("하하! 좋습니다! 그럼 당신에게 ３000금이 있을 때, 언제든지 나를 찾아 오십시오! ");
textSQuest4[2].push("당신은 저축하는 습관이 없군요, 저축하고 싶은 생각은 없습니까? 그럼 경제 위기가 닥치면, 어떻게 난관을 헤쳐 나갈 생각입니까? 돈은 정말 아주 중요한 것입니다! ");
textSQuest4[3].push("보아하니 돈을 버는 것이 용사의 입장에서는 결코 매우 익숙한 활동은 아닌 것 같군요……아직 ３000금도 모으지 못했습니까?? ");
textSQuest4[4].push("난 금화가 서로 부딪치는 소리를 들었습니다! 얼마나 아름답고도 즐거운 음악입니까! 축하 드립니다. 당신은 제가 한동안 시간을 들여 고른 가장 좋은 무기-암살자를 획득할 수 있습니다! ");
textSQuest4[5].push("저축의 의미(부분 임무) ");
textSQuest4[6].push("상인 장씨를 위해 ３000금을 저축하고, 그의 소중한 보배를 만회하라. ");
textSQuest5[0].push("나는 더욱 좋은 무기와 방어구를 만들고 싶습니다! 그러기 위해 난 더욱 좋은 철광석이 필요합니다! 듣자니 북쪽의 신비의 동굴에서 최상의 철광석을 찾을 수 있다고 합니다! 우리 할아버지도 사용한 적이 있는 것 같습니다! 조금이라도 찾아 돌아 온다면, 어쩌면 제가 만드는 물건이 더욱 좋아 질 수도 있습니다! 당신이 저를 도와 그곳에 가서 약간의 철광석을 찾아 올 수 있겠습니까? ");
textSQuest5[1].push("고맙습니다. 신비의 동굴에는 괴물이 출몰합니다. 안전에 주의하도록 하십시오! ");
textSQuest5[2].push("당신이 한가할 때 나를 좀 도와주었으면 좋겠는데! 나를 도와주기 싫은 겁니까? 날 싫어하는 겁니까……! ");
textSQuest5[3].push("철광석을 찾았습니까? 그것은 광갱 속에 있습니다. 괴물을 조심하십시오! ");
textSQuest5[4].push("야! 이건 정말 특별한 철광석이야! 이 반짝이는 빛 좀 봐! 이걸 이용하면 반드시 최고의 장비를 만들 수 있을 꺼야! 고맙습니다! 이것은 당신에게 주는 도끼입니다! ");
textSQuest5[5].push("반짝이는 철광석(부분 임무) ");
textSQuest5[6].push("대장장이 그랜을 위해서 북쪽의 신비의 동굴 속에서 철광석을 찾아라. ");
textSQuest6[0].push("합성에 대해 조금 이해 했나요? 작은 병의 약제는 큰 병의 약제로 합성할 수 있습니다. 만약 가능하다면, 당신이 저를 도와 대형 특효 약제 한 병을 합성해 줄 수 있나요? 어떤 물질로 합성할 것인지는, 당신 자신에게 달려 있습니다. 합성에 성공 한 후, 저는 당신에게 아주 특별한 약제를 상으로 줄 것입니다! ");
textSQuest6[1].push("그럼 수고해주십시오. 이 또한 당신이 합성 규칙을 이해할 수 있는 절호의 기회입니다. 마치 화학 수업을 듣는 것처럼요. ");
textSQuest6[2].push("그렇지만 당신이 합성 규칙을 연구할 수 있는 모처럼 드는 기회인데, 포기하다니 너무 아쉽군요. ");
textSQuest6[3].push("합성은 아주 심오한 학문입니다. 여러 차례 해보면 약간의 규칙을 찾아 낼 수 있을 것입니다. ");
textSQuest6[4].push("잘했습니다~보아하니 당신은 몇몇 합성의 규칙을 파악한 것 같군요! 자,  당신에게 아마도 당신이 이제까지 본적이 없는 약제 몇 병을 드리겠습니다. ");
textSQuest6[5].push("화학 수업(부분 임무) ");
textSQuest6[6].push("수잔을 위하여 대형 특효 약제 1병을 합성하라. ");
textSQuest7[0].push("어이! 친구! 난 지금 열심히 새로운 무기를 만들고 있다네! 난 일명 기사의 방패라고 불리는 방패를 만들었어! 나는 그것에 추가하고 싶은 것이 있네: 방어력 상승 lv.2 , 저항률(block) lv.2 증가, 이 두 종류의 속성을 추가 하고 싶네! 나를 도와줄 수 있겠나! 원소석을 이용해 합성할 수 있다네! ");
textSQuest7[1].push("고맙소! 완성 되면 다시 나를 찾아와 주십시오! ");
textSQuest7[2].push("날 도와주기 싫은 겁니까! 당신은 내 솜씨를 좋아하지 않는군요! ");
textSQuest7[3].push("어떻게! 기사의 방패 합성에 문제라도 생긴 겁니까! 당연히 내 방패 만드는 기술이 원인은 아니겠지! ");
textSQuest7[4].push("어디 한번 봅시다! 하하! 맞아! 바로 이런 방패야! 보시오! 이러한 속성을 추가한 후에 그것이 얼마나 훌륭한지! 당신은 정말 훌륭한 합성가 입니다! 이렇게 합시다! ");
textSQuest7[5].push("당신에게 이 방패를 공짜로 선물 하겠습니다! 그리고 더하여 내가 방금 만든 장갑 한 세트도 드리겠습니다! 나는 천천히 진보할 것 입니다! 이후에는 더욱 좋은 물건을 만들 것입니다! ");
textSQuest7[6].push("그랜의 노력(부분 임무) ");
textSQuest7[7].push("그랜을 도와 방어력(%) lv.2, 저항률lv.2의 방패를 합성하라. ");
textSkill[0].push("칼의 숙련도(피동 기능): 사용하는 무기가 칼일 때, 초과의 숙련 데미지가 있다. 칼의 숙련도가 높을수록 칼을 휘두르는 속도도 더욱 빨라진다. ");
textSkill[1].push("도끼의 숙련도(피동 기능): 사용하는 무기가 도끼일 때, 초과의 숙련 데미지가 있다. 도끼의 숙련도가 높을수록 도끼를 휘두르는 속도도 더욱 빨라진다. ");
textSkill[2].push("검의 숙련도(피동 기능): 사용하는 무기가 검일 때, 초과의 숙련 데미지가 있다. 검의 숙련도가 높을수록, 검을 휘두르는 속도도 더욱 빨라진다. ");
textSkill[3].push("중량 증가(피동 기능): 주인공의 중량이 증가하면, 더욱 많은 물건을 지닐 수 있다. ");
textSkill[4].push("빠른 회복(피동 기능): 주인공의 HP와 SP의 회복 속도를 빠르게 한다. ");
textSkill[5].push("창 끝을 돌려 반격(피동 기능): 주인공이 구타 당하고 있을 때, 일정한 확률에 따라 광포 기능이 자동으로 일어난다. ");
textSkill[6].push("전체 속성 증가(피동 기능): 주인공의 모든 속성이 증가");
textSkill[7].push("칼의 최종 기능(피동 기능): 사용하는 무기가 칼일 때, 연타 공격의 횟수가 한 차례 증가하며, 최후의 공격으로 적을 하늘로 보낼 수 있다. ");
textSkill[8].push("도끼의 최종 기능(피동 기능): 사용하는 무기가 도끼일 때, 연타 공격의 횟수가 한 차례 증가하며, 최후의 공격에서 높이 도약하여 일격을 가함으로써, 주위의 적들에게 데미지를 줄 수 있다. ");
textSkill[9].push("검의 최종 기능(피동 기능): 사용하는 무기가 검일 때, 연타 공격의 횟수가 한 차례 증가하며, 최후의 공격에서 힘찬 전방 찌르기는, 전방의 적들에게 데미지를 줄 수 있다. ");
textSkill[10].push("칼의 특수 기능(주동 기능): 연속적인 찌르기를 통해, 한명의 적에게 심각한 데미지를 줄 수 있다. 시작 후 연속적으로 공격 버튼을 눌러 줘야 한다. ");
textSkill[11].push("도끼의 특수 기능(주동 기능): 강력한 한번의 내려 찍기는, 주변 지역에 강력한 데미지를 줄 수 있다. ");
textSkill[12].push("검의 특수 기능(주동 기능): 고속 앞 찌르기는, 전방의 적들에게 강력한 데미지를 줄 수 있다. ");
textSkill[13].push("회오리바람 기능(주동 기능): 자신이 고속으로 회전하여, 근처의 적들이 사라지게 할 수 있으며, 그들에게 강력한 데미지를 줄 수 있다. ");
textSkill[14].push("회오리바람 기능 II(주동 기능): 자신이 고속으로 회전하여, 먼저 강력한 근처의 적들을 흡착한 후, 다시 그들이 사라지게 함으로써, 그들에게 강력한 데미지를 가할 수 있다. ");
textSkill[15].push("검성(劍聖) 폭풍(주동 기능): 자신이 지속적으로 끊임없이 고속 회전하며, 강대한 폭풍을 형성, 적에게로 이동함으로써 그들에게 강력한 데미지를 가할 수 있다. ");
textSkill[16].push("검기(劍氣) 방출(주동 기능): 힘껏 한번 휘두르면 강력한 검기가 방출되며, 검기는 적에게 데미지를 줄 수 있다. ");
textSkill[17].push("마법 속성 방출(주동 기능): 무기에 불, 얼음, 천둥, 독 등의 데미지 속성이 있을 때, 힘껏 한번 휘두르면 무기의 속성이 방출되어, 적에게 속성 데미지를 가할 수 있다. ");
textSkill[18].push("최종 마법 속성 방출(주동 기능): 강력한 충격파가 방출되어, 근처의 모든 적들에게 치명적인 속성 데미지를 가할 수 있다. ");
textSkill[19].push("광포(주동 기능): 스스로의 공격을 강화 시킴으로써, 약화된 광포 상태를 방어하고, 높은 공격력을 획득할 수 있다. 그러나 아주 쉽게 부상 당할 수 있다. ");
textSkill[20].push("가속(주동 기능): 갑자기 스스로를 흥분시켜, 이동 속도를 빠르게 할 수 있다. ");
textSkill[21].push("신성의 빛(주동 기능): 신성의 빛에 비호를 얻어, 일시적으로 자신의 HP와 SP를 상승시킬 수 있으며, 설령 이미 사망했더라도 다시 한번 부활 할 수 있다. ");
